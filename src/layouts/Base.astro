---
import settings from '../lib/settings';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
}

const { title, description = settings.metaDescription ?? '', showNav = true } = Astro.props;
const pageTitle = title ? `${title} — ${settings.siteName}` : settings.siteName;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible+Next:wght@400;600&family=Faculty+Glyphic&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      showNav && (
        <nav class="site-nav">
          <div class="wrap nav-row">
            <a href="/">{settings.siteName}</a>
            <a href="/about/">About</a>
          </div>
        </nav>
      )
    }

    <slot />

    <footer class="site-footer">
      <div class="wrap">
        <h2>Contact</h2>
        {
          settings.email && (
            <p class="footer-email">
              <a href={`mailto:${settings.email}`}>{settings.email}</a>
            </p>
          )
        }
        {
          settings.socials.length > 0 && (
            <ul class="socials">
              {settings.socials.map((s) => (
                <li>
                  <a href={s.url ?? '#'} rel="me noopener">
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
        <p class="fineprint">© {year} {settings.siteName}</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #000;
    --ink: #d9d9d9;
    --bright: #f5f5f5;
    --muted: #8c8c8c;
    --rule: #232323;
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    margin: 0;
    font-family: 'Atkinson Hyperlegible Next', system-ui, sans-serif;
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--ink);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: 'Faculty Glyphic', serif;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: 0.01em;
    margin: 0 0 0.6em;
    color: var(--bright);
  }

  a {
    color: inherit;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255, 255, 255, 0.35);
  }

  a:hover {
    text-decoration-color: rgba(255, 255, 255, 0.7);
  }

  ::selection {
    background: rgba(255, 255, 255, 0.9);
    color: #000;
  }

  strong {
    font-weight: 600;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  figure {
    margin: 2.5rem 0;
  }

  figcaption {
    margin-top: 0.6rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .wrap {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Nav (non-home pages) */
  .site-nav {
    border-bottom: 1px solid var(--rule);
  }

  .nav-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
  }

  .nav-row a {
    text-decoration: none;
  }

  .nav-row a:first-child {
    font-family: 'Faculty Glyphic', serif;
    font-size: 1.15rem;
  }

  .nav-row a:hover {
    text-decoration: underline;
  }

  /* Long-form content (Markdoc output).
     Text sits in a centered reading column; tables, code blocks, and
     images stretch across the full width of the page. */
  .prose > :first-child {
    margin-top: 0;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote,
  .prose hr,
  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    max-width: 46rem;
    margin-inline: auto;
  }

  /* Consistent heading hierarchy — the browser default shrinks h1
     inside <article>, which inverted the scale. Space above scales
     with heading size to break up the page. */
  .prose h1 {
    font-size: 2rem;
    margin-block: 3.5rem 1rem;
  }

  .prose h2 {
    font-size: 1.6rem;
    margin-block: 3rem 0.9rem;
  }

  .prose h3 {
    font-size: 1.3rem;
    margin-block: 2.4rem 0.8rem;
  }

  .prose h4,
  .prose h5,
  .prose h6 {
    font-size: 1.1rem;
    margin-block: 2rem 0.7rem;
  }

  .prose :is(h1, h2, h3, h4, h5, h6) + :is(h1, h2, h3, h4, h5, h6) {
    margin-top: 0.5rem;
  }

  /* Tables span the full width */
  .prose table {
    width: 100%;
    margin: 2.5rem 0;
    border-collapse: collapse;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .prose th,
  .prose td {
    border: 1px solid var(--rule);
    padding: 0.65rem 0.9rem;
    text-align: left;
    vertical-align: top;
  }

  .prose th {
    font-weight: 600;
    color: var(--bright);
    background: rgba(255, 255, 255, 0.045);
  }

  /* Code blocks (Shiki adds its own background) */
  .prose pre {
    margin: 2.5rem 0;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .prose :not(pre) > code {
    font-family: ui-monospace, 'SFMono-Regular', 'Menlo', 'Consolas', monospace;
    font-size: 0.9em;
    background: rgba(255, 255, 255, 0.09);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose blockquote {
    border-left: 3px solid rgba(255, 255, 255, 0.35);
    padding-left: 1.25rem;
    color: var(--muted);
  }

  .prose blockquote > :first-child {
    margin-top: 0;
  }

  .prose blockquote > :last-child {
    margin-bottom: 0;
  }

  .prose hr {
    border: 0;
    border-top: 1px solid var(--rule);
    margin-block: 3rem;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--rule);
    margin-top: 6rem;
    padding: 3.5rem 0 3rem;
  }

  .site-footer h2 {
    font-size: 1.3rem;
  }

  .footer-email {
    margin: 0 0 0.5rem;
  }

  .socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .fineprint {
    margin-top: 2.5rem;
    font-size: 0.875rem;
    color: var(--muted);
  }
</style>
