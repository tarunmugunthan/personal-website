---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';

const about = await getEntry('about', 'index');
if (!about) throw new Error('About page not found. Create it in /keystatic.');

const { Content } = await render(about);
---

<Base title={about.data.title}>
  <main class="wrap">
    <div class="about-grid">
      {
        about.data.portrait && (
          <div class="portrait">
            <Image
              src={about.data.portrait}
              alt={about.data.portraitAlt ?? ''}
              widths={[480, 800]}
              sizes="(max-width: 760px) 100vw, 40vw"
              loading="eager"
            />
          </div>
        )
      }
      <div class="prose">
        <h1>{about.data.title}</h1>
        <Content />
      </div>
    </div>
  </main>
</Base>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3.5rem;
    align-items: start;
    padding: 4rem 0 0;
  }

  .portrait img {
    width: 100%;
  }

  @media (max-width: 760px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
