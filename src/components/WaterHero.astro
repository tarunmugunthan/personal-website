---
interface Props {
  siteName: string;
  text: string;
}
const { siteName, text } = Astro.props;
---

<header class="water-hero">
  <canvas id="gl"></canvas>
  <pre id="err"></pre>
  <h1 class="sr-only">{siteName}</h1>
  <div class="hero-text">
    <div class="hero-panel">
      <p>{text}</p>
    </div>
  </div>
</header>

<style>
  .water-hero {
    position: relative;
    height: 100vh;
    height: 100svh;
    background: #02080c;
    overflow: hidden;
  }
  #gl {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    /* pan-y keeps vertical swipes scrolling the page on touch screens;
       taps still land as pointerdown ripples */
    touch-action: pan-y;
    cursor: crosshair;
  }
  #err {
    position: absolute;
    inset: 0;
    display: none;
    place-items: center;
    padding: 32px;
    background: #02080c;
    color: #ff9d8a;
    font-family: ui-monospace, 'SFMono-Regular', 'Menlo', 'Consolas', monospace;
    font-size: 12px;
    line-height: 1.6;
    white-space: pre-wrap;
    overflow: auto;
    z-index: 5;
  }
  .hero-text {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }
  .hero-panel {
    /* the black rectangle is carved out of the simulation itself; the
       panel tracks the gap's centre via --hole-x set from the script */
    position: absolute;
    left: var(--hole-x, 50%);
    top: 50%;
    transform: translate(-50%, -50%);
    width: max-content;
    max-width: min(32rem, 86vw);
    padding: 0 1.5rem;
    text-align: center;
  }
  .hero-panel p {
    margin: 0;
    font-family: 'Faculty Glyphic', serif;
    font-size: clamp(1.3rem, 2.4vw, 1.75rem);
    line-height: 1.5;
    color: #f5f5f5;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
</style>

<script is:inline>
(() => {
  // ---- settings -----------------------------------------------------------
  const CONFIG = {
    wind:     0.00,      // 0..1   wave height + choppiness
    angle:    52,        // 20..89 camera elevation. 89 is effectively straight down.
    sun:      1.00,      // 0..1   sun height in the sky
    speed:    0.80,      // 0.25..2.6  ripple wavefront speed
    contrast: 2.50,      // tone curve applied before the glyph ramp
    sunCol:   '#ffffff',                                     // rgb(255, 255, 255)
    waterCol: '#0062ff',                                     // rgb(0, 98, 255)

    // --- ascii pass ---
    // Squares only. Order doesn't matter: the atlas measures each glyph's ink
    // and sorts the ramp dark -> bright itself. Any glyph the font can't render
    // is dropped rather than drawn as a tofu box.
    ramp:     '\u00B7\u25AB\u25AA\u25A1\u25A3\u25A0',   //  · ▫ ▪ □ ▣ ■
    cellW:    10,        // character cell, CSS px
    cellH:    16,
    weight:   0,         // extra stroke on each glyph — fills don't need it
    lift:     1.0,       // glyph alpha gain
    levels:   4,         // colour posterisation steps per channel
    glowBg:   0.06,      // scene colour bleeding into the cell background

    // --- cursor trail ---
    trailMs:  45,        // min time between emitted ripples
    trailPx:  7,         // min cursor travel between emitted ripples
  };

  const canvas = document.getElementById('gl');
  const errBox = document.getElementById('err');
  const hero = canvas.parentElement;   // .water-hero — carries --hole-x for the text

  function fail(msg) {
    errBox.textContent = msg;
    errBox.style.display = 'grid';
  }

  const gl = canvas.getContext('webgl', { antialias: false, alpha: false, powerPreference: 'high-performance' })
          || canvas.getContext('experimental-webgl');

  if (!gl) {
    fail('This browser has no WebGL context available.\nTry another browser, or enable hardware acceleration.');
    return;
  }

  const MAX = 32;   // live ripples — a cursor trail needs many more than a click did

  const VERT = `
    attribute vec2 aPos;
    void main() { gl_Position = vec4(aPos, 0.0, 1.0); }
  `;

  // =========================================================================
  // PASS 1 — the water, rendered at one pixel per character cell.
  // =========================================================================
  const FRAG_SCENE = `
    precision highp float;

    uniform vec2  uRes;       // low-res buffer = the character grid
    uniform float uAspect;    // true screen aspect
    uniform float uTime;
    uniform float uWind;
    uniform float uSun;
    uniform vec3  uSunTint;
    uniform vec3  uWaterCol;
    uniform float uAngle;
    uniform float uRipSpeed;
    uniform vec4  uRip[${MAX}];

    const float ORBIT = 6.39;

    float hash(vec2 p) {
      p = fract(p * vec2(443.897, 441.423));
      p += dot(p, p.yx + 19.19);
      return fract((p.x + p.y) * p.x);
    }

    float noise(vec2 p) {
      vec2 i = floor(p);
      vec2 f = fract(p);
      vec2 u = f * f * (3.0 - 2.0 * f);
      float a = hash(i);
      float b = hash(i + vec2(1.0, 0.0));
      float c = hash(i + vec2(0.0, 1.0));
      float d = hash(i + vec2(1.0, 1.0));
      return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
    }

    float fbm(vec2 p) {
      float v = 0.0;
      float a = 0.5;
      mat2 r = mat2(0.86, -0.51, 0.51, 0.86);
      for (int i = 0; i < 4; i++) {
        v += a * noise(p);
        p = r * p * 2.03;
        a *= 0.5;
      }
      return v;
    }

    float swell(vec2 p, float detail) {
      float h = 0.0;
      float amp = 0.5;
      float freq = 0.85;
      vec2 q = p;
      mat2 rot = mat2(0.86, -0.51, 0.51, 0.86);

      for (int i = 0; i < 6; i++) {
        float lod = (i < 2) ? 1.0 : detail;
        vec2 drift = vec2(0.85, 0.32) * uTime * (0.22 + 0.10 * float(i));
        float n = noise(q * freq + drift) * 2.0 - 1.0;
        h += n * amp * lod;
        q = rot * q;
        amp *= 0.54;
        freq *= 2.06;
      }

      float chop = 0.30 + 0.45 * uWind;
      h = sign(h) * pow(abs(h), 1.0 - 0.55 * chop);
      return h * (0.10 + 0.30 * uWind);
    }

    float capillary(vec2 p, float detail) {
      float a = noise(p *  9.0 + vec2(-uTime * 0.55, uTime * 0.40)) - 0.5;
      float b = noise(p * 19.0 + vec2( uTime * 0.80, uTime * 0.25)) - 0.5;
      return (a * 0.0090 + b * 0.0040) * (0.35 + uWind) * detail;
    }

    float ripples(vec2 p) {
      float h = 0.0;
      for (int i = 0; i < ${MAX}; i++) {
        vec4 r = uRip[i];
        if (r.w <= 0.0) continue;
        float age = uTime - r.z;
        if (age < 0.0 || age > 4.0) continue;
        float d = length(p - r.xy);
        float front = d - age * uRipSpeed;
        float env = exp(-age * 1.55) * exp(-front * front * 34.0) * exp(-d * 0.30);
        float s = sin(front * 26.0);
        s = sign(s) * pow(abs(s), 1.45);
        h += (s + 0.30 * sin(front * 52.0 + 1.0)) * env * r.w;
      }
      return h;
    }

    float height(vec2 p, float detail) {
      return swell(p, detail) + ripples(p) + capillary(p, detail);
    }

    vec3 normalAt(vec2 p, float eps, float detail) {
      float h  = height(p, detail);
      float hx = height(p + vec2(eps, 0.0), detail);
      float hz = height(p + vec2(0.0, eps), detail);
      return normalize(vec3(h - hx, eps, h - hz));
    }

    vec3 sky(vec3 rd, vec3 sunDir) {
      float y = max(rd.y, 0.0);
      vec3 zenith  = vec3(0.05, 0.26, 0.62);
      vec3 horizon = vec3(0.68, 0.80, 0.88);
      horizon = mix(horizon, uSunTint, 0.28);
      vec3 col = mix(horizon, zenith, pow(y, 0.45));

      float band = exp(-abs(rd.y - 0.16) * 14.0);
      float c = fbm(rd.xz / max(rd.y + 0.10, 0.10) * 0.9 + uTime * 0.012);
      col = mix(col, mix(vec3(0.93, 0.94, 0.95), uSunTint, 0.35), smoothstep(0.45, 0.85, c) * band * 0.55);

      float sd = max(dot(rd, sunDir), 0.0);
      col += uSunTint * pow(sd, 900.0) * 14.0;
      col += uSunTint * pow(sd, 7.0) * 0.30;
      return col;
    }

    float caustic(vec2 p) {
      float a = noise(p * 2.6 + vec2( uTime * 0.11, -uTime * 0.08));
      float b = noise(p * 4.3 - vec2( uTime * 0.09,  uTime * 0.12));
      float v = abs(a - b);
      return pow(1.0 - clamp(v * 3.2, 0.0, 1.0), 7.0);
    }

    vec3 floorColor(vec2 p) {
      float grain = fbm(p * 1.4);
      vec3 sand = mix(vec3(0.42, 0.40, 0.31), vec3(0.60, 0.57, 0.44), grain);
      sand += vec3(1.00, 0.92, 0.70) * caustic(p) * 0.55;
      return sand;
    }

    void main() {
      vec2 uv = gl_FragCoord.xy / uRes - 0.5;
      uv.x = -uv.x;   // mirror the scene: sun glint moves left, dark water right
      uv.x *= uAspect;

      float ang = radians(clamp(uAngle, 5.0, 89.0));
      vec3 ro = vec3(0.0, ORBIT * sin(ang), ORBIT * cos(ang));
      vec3 ww = normalize(-ro);
      vec3 uu = normalize(cross(ww, vec3(0.0, 1.0, 0.0)));
      vec3 vv = cross(uu, ww);
      vec3 rd = normalize(uv.x * uu + uv.y * vv + 1.60 * ww);

      float el = mix(0.05, 0.72, uSun);
      vec3 sunDir = normalize(vec3(0.30, el, -1.0));

      vec3 col;

      if (rd.y > -0.0025) {
        col = sky(rd, sunDir);
      } else {
        float t = -ro.y / rd.y;
        vec3 pos = ro + rd * t;
        vec2 p = pos.xz;

        float detail = 1.0 / (1.0 + t * t * 0.0055);
        float eps = max(0.0045, t * 0.0022);
        vec3 N = normalAt(p, eps, detail);
        vec3 V = -rd;

        vec3 refr = refract(rd, N, 1.0 / 1.333);
        float depth = 1.35;
        vec2 fp = p + refr.xz * (depth / max(-refr.y, 0.25));
        vec3 below = floorColor(fp);

        // Absorption follows the water colour: darkened channels absorb fastest,
        // so the depths converge on whatever hue you pick.
        vec3 tint = max(uWaterCol, vec3(0.015));
        vec3 absorbK = -log(tint) * 0.42;
        below *= exp(-absorbK * depth * 1.9);
        below = mix(below, tint * 0.70, 0.48);

        vec3 R = reflect(rd, N);
        R.y = abs(R.y);
        vec3 above = sky(R, sunDir);

        float fres = 0.02 + 0.98 * pow(1.0 - max(dot(N, V), 0.0), 5.0);
        col = mix(below, above, fres);

        vec3 H = normalize(sunDir + V);
        float spec = pow(max(dot(N, H), 0.0), 600.0);
        col += uSunTint * spec * 4.0;

        float h = height(p, detail);
        float steep = 1.0 - N.y;
        float foam = smoothstep(0.35, 0.85, h * 6.0 * (0.4 + uWind)) * smoothstep(0.02, 0.12, steep);
        foam *= smoothstep(0.35, 0.75, fbm(p * 7.0 + uTime * 0.25));
        col = mix(col, vec3(0.92, 0.95, 0.96), clamp(foam, 0.0, 0.75) * detail);

        float haze = 1.0 - exp(-t * 0.055);
        col = mix(col, sky(vec3(rd.x, 0.008, rd.z), sunDir), haze * 0.92);
      }

      col = col / (1.0 + col);
      col = pow(col, vec3(0.4545));

      gl_FragColor = vec4(clamp(col, 0.0, 1.0), 1.0);
    }
  `;

  // =========================================================================
  // PASS 2 — one texel per cell -> the square whose coverage matches that
  // cell's brightness. With only six squares the ramp is coarse, so the tone
  // curve does the heavy lifting: it decides which cells cross each step.
  // =========================================================================
  const FRAG_ASCII = `
    precision highp float;

    uniform sampler2D uScene;
    uniform sampler2D uGlyphs;
    uniform vec2  uCell;
    uniform vec2  uGrid;
    uniform vec2  uRes;
    uniform float uCount;
    uniform float uLevels;
    uniform float uBg;
    uniform float uContrast;
    uniform float uLift;
    uniform vec4  uHole;      // centered text gap, in cell coords: x0, y0, x1, y1
    uniform sampler2D uFace;
    uniform vec4  uFaceRect;  // portrait region, device px, bottom-origin
    uniform float uFaceOn;

    vec3 punch(vec3 c, float k) {
      return clamp((c - 0.5) * k + 0.5, 0.0, 1.0);
    }

    void main() {
      vec2 cell   = floor(gl_FragCoord.xy / uCell);
      vec2 inCell = (gl_FragCoord.xy - cell * uCell) / uCell;

      // rectangular gap in the glyph field: the animation simply stops here —
      // cells inside are pure black, cells outside render at full strength
      vec2 dOut = max(uHole.xy - cell, cell - uHole.zw);
      if (max(dOut.x, dOut.y) <= 0.0) {
        gl_FragColor = vec4(0.0, 0.0, 0.0, 1.0);
        return;
      }

      vec3 raw = texture2D(uScene, (cell + 0.5) / uGrid).rgb;
      vec3 c = punch(raw, uContrast);

      float lum = dot(c, vec3(0.299, 0.587, 0.114));
      lum = clamp((lum - 0.46) * uContrast + 0.46, 0.0, 0.9999);

      // face overlay: the portrait's ink lifts the glyph ramp on the right.
      // The lift is modulated by the live water luminance, so passing
      // ripples visibly disturb the face and it settles back as they decay.
      // Sampled unconditionally (uv clamped, effect masked arithmetically):
      // mipmap LOD selection inside a non-uniform branch is undefined.
      vec2 cpx = (cell + 0.5) * uCell;
      vec2 fuv = clamp((cpx - uFaceRect.xy) / max(uFaceRect.zw - uFaceRect.xy, vec2(1.0)), 0.0, 1.0);
      float ink = 1.0 - texture2D(uFace, fuv).r;       // black ink on white
      // gentle curve: keeps the dither's gradient shading instead of
      // crushing mid-tones to full ink
      ink = smoothstep(0.08, 0.72, ink);
      vec2 inR = step(uFaceRect.xy, cpx) * step(cpx, uFaceRect.zw);
      // fade only at the left and top — the portrait is flush with the
      // right and bottom edges of the hero
      vec2 eD = vec2(cpx.x - uFaceRect.x, uFaceRect.w - cpx.y);
      float fEdge = smoothstep(0.0, 40.0, min(eD.x, eD.y));
      float fMask = ink * fEdge * inR.x * inR.y * uFaceOn;
      float shimmer = 0.55 + 0.75 * lum;
      lum = clamp(mix(lum, ink * shimmer, 0.95 * fMask), 0.0, 0.9999);

      float idx = floor(lum * uCount);

      // inset a hair so bilinear filtering can't drag in the neighbouring glyph
      float gx = (idx + mix(0.02, 0.98, inCell.x)) / uCount;
      float g  = clamp(texture2D(uGlyphs, vec2(gx, 1.0 - inCell.y)).a * uLift, 0.0, 1.0);

      float mx = max(c.r, max(c.g, c.b));
      vec3 tint = mix(c, c / max(mx, 0.001), 0.86);
      tint = floor(tint * uLevels + 0.5) / uLevels;
      tint *= 0.45 + 0.55 * lum;          // keep the ramp readable as brightness

      vec3 bg = vec3(0.008, 0.024, 0.032) + c * uBg;
      vec3 col = mix(bg, tint, g);

      // ink cells drift toward white so the portrait separates from the water
      col = mix(col, vec3(0.93, 0.96, 1.0) * g, 0.85 * fMask);

      // hairline gutter under each row, so the grid stays legible
      col *= 0.90 + 0.10 * step(0.09, inCell.y);

      vec2 q = gl_FragCoord.xy / uRes;
      col *= 0.78 + 0.22 * pow(16.0 * q.x * q.y * (1.0 - q.x) * (1.0 - q.y), 0.18);

      gl_FragColor = vec4(clamp(col, 0.0, 1.0), 1.0);
    }
  `;

  function compile(type, src) {
    const s = gl.createShader(type);
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      throw new Error(gl.getShaderInfoLog(s) || 'shader compile failed');
    }
    return s;
  }

  function link(fragSrc) {
    const p = gl.createProgram();
    gl.attachShader(p, compile(gl.VERTEX_SHADER, VERT));
    gl.attachShader(p, compile(gl.FRAGMENT_SHADER, fragSrc));
    gl.linkProgram(p);
    if (!gl.getProgramParameter(p, gl.LINK_STATUS)) {
      throw new Error(gl.getProgramInfoLog(p) || 'program link failed');
    }
    return p;
  }

  let scenePM, asciiPM;
  try {
    scenePM = link(FRAG_SCENE);
    asciiPM = link(FRAG_ASCII);
  } catch (e) {
    fail('Shader problem:\n\n' + e.message);
    return;
  }

  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);

  const S = {
    aPos:     gl.getAttribLocation(scenePM, 'aPos'),
    res:      gl.getUniformLocation(scenePM, 'uRes'),
    aspect:   gl.getUniformLocation(scenePM, 'uAspect'),
    time:     gl.getUniformLocation(scenePM, 'uTime'),
    wind:     gl.getUniformLocation(scenePM, 'uWind'),
    sun:      gl.getUniformLocation(scenePM, 'uSun'),
    sunTint:  gl.getUniformLocation(scenePM, 'uSunTint'),
    waterCol: gl.getUniformLocation(scenePM, 'uWaterCol'),
    angle:    gl.getUniformLocation(scenePM, 'uAngle'),
    ripSpeed: gl.getUniformLocation(scenePM, 'uRipSpeed'),
    rip:      gl.getUniformLocation(scenePM, 'uRip[0]'),
  };

  const A = {
    aPos:     gl.getAttribLocation(asciiPM, 'aPos'),
    scene:    gl.getUniformLocation(asciiPM, 'uScene'),
    glyphs:   gl.getUniformLocation(asciiPM, 'uGlyphs'),
    cell:     gl.getUniformLocation(asciiPM, 'uCell'),
    grid:     gl.getUniformLocation(asciiPM, 'uGrid'),
    res:      gl.getUniformLocation(asciiPM, 'uRes'),
    count:    gl.getUniformLocation(asciiPM, 'uCount'),
    levels:   gl.getUniformLocation(asciiPM, 'uLevels'),
    bg:       gl.getUniformLocation(asciiPM, 'uBg'),
    contrast: gl.getUniformLocation(asciiPM, 'uContrast'),
    lift:     gl.getUniformLocation(asciiPM, 'uLift'),
    hole:     gl.getUniformLocation(asciiPM, 'uHole'),
    face:     gl.getUniformLocation(asciiPM, 'uFace'),
    faceRect: gl.getUniformLocation(asciiPM, 'uFaceRect'),
    faceOn:   gl.getUniformLocation(asciiPM, 'uFaceOn'),
  };

  const ORBIT = 6.39;   // must match the shader

  // ---- glyph atlas ---------------------------------------------------------
  // Three jobs beyond drawing:
  //   1. tofu check — these are Unicode maths symbols, and a font that lacks one
  //      draws a filled box. A box has *more* ink than every real glyph here, so
  //      it would silently become the "brightest" step. Anything that renders
  //      identically to a guaranteed-missing codepoint gets dropped.
  //   2. stroke weight — tildes are hairlines; at this cell size they'd vanish,
  //      so each glyph is stroked as well as filled to thicken it.
  //   3. sort by ink, so the ramp runs dark -> bright whatever the font does.
  function buildGlyphAtlas(chars, cw, ch, weight) {
    const SS = 3;
    const W = cw * SS, H = ch * SS;
    // slight overfill, clipped to the cell: a filled block should reach the edges
    const FONT = `600 ${Math.round(H * 1.06)}px ui-monospace, "SFMono-Regular", "Menlo", "Consolas", "DejaVu Sans Mono", "Segoe UI Symbol", "Noto Sans Symbols 2", sans-serif`;

    const setup = (ctx) => {
      ctx.font = FONT;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = '#fff';
      ctx.strokeStyle = '#fff';
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      ctx.lineWidth = Math.max(1, H * weight);
    };

    const stamp = (ctx, glyph, x0) => {
      ctx.save();
      ctx.beginPath();
      ctx.rect(x0, 0, W, H);
      ctx.clip();
      const cx = x0 + W * 0.5, cy = H * 0.5;
      if (weight > 0) ctx.strokeText(glyph, cx, cy);   // only hairline glyphs need thickening
      ctx.fillText(glyph, cx, cy);
      ctx.restore();
    };

    const m = document.createElement('canvas');
    m.width = W; m.height = H;
    const mc = m.getContext('2d', { willReadFrequently: true });
    setup(mc);

    const render = (glyph) => {
      mc.clearRect(0, 0, W, H);
      stamp(mc, glyph, 0);
      const d = mc.getImageData(0, 0, W, H).data;
      let ink = 0;
      const sig = [];
      for (let i = 3; i < d.length; i += 4) {
        ink += d[i];
        if ((i % 97) === 3) sig.push(d[i]);   // cheap fingerprint
      }
      return { ink, sig: sig.join(',') };
    };

    const tofu = render('\uFFFE');   // a permanently unassigned codepoint

    const kept = [...chars]
      .map((glyph) => ({ glyph, ...render(glyph) }))
      .filter((x) => x.ink > 0 && x.sig !== tofu.sig)
      .sort((a, b) => a.ink - b.ink);

    // if the font somehow has none of them, fall back to something universal
    const sorted = kept.length >= 2 ? kept.map((x) => x.glyph) : [...'.-=+*#'];

    const c = document.createElement('canvas');
    c.width = sorted.length * W;
    c.height = H;
    const g = c.getContext('2d');
    setup(g);
    sorted.forEach((glyph, i) => stamp(g, glyph, i * W));

    const tex = gl.createTexture();
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, c);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
    return { tex, count: sorted.length, glyphs: sorted.join(' ') };
  }

  const atlas = buildGlyphAtlas(CONFIG.ramp, CONFIG.cellW, CONFIG.cellH, CONFIG.weight);

  // ---- face overlay ---------------------------------------------------------
  // Black-ink portrait sampled per cell on the right side of the hero.
  // Starts as a 1x1 white pixel (ink = 0, no effect) until the image loads.
  const faceTex = gl.createTexture();
  gl.bindTexture(gl.TEXTURE_2D, faceTex);
  gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE,
    new Uint8Array([255, 255, 255, 255]));
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);

  let faceReady = false;
  let faceAspect = 1;
  let faceOn = false;
  const faceRect = new Float32Array(4);

  const faceImg = new Image();
  faceImg.onload = () => {
    faceAspect = faceImg.width / faceImg.height;
    // normalise to power-of-two via canvas (stretch; the draw rect keeps
    // the true aspect) so mipmaps always work — they keep the downsample
    // to cells clean, whatever the source dimensions
    const potCanvas = document.createElement('canvas');
    potCanvas.width = 1024;
    potCanvas.height = 1024;
    potCanvas.getContext('2d').drawImage(faceImg, 0, 0, 1024, 1024);
    gl.bindTexture(gl.TEXTURE_2D, faceTex);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, true);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, potCanvas);
    gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, false);
    gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR_MIPMAP_LINEAR);
    gl.generateMipmap(gl.TEXTURE_2D);
    faceReady = true;
    // draw one frame right away so the face shows even if the tab is
    // backgrounded (rAF is paused there) when the image finishes loading
    const was = running;
    running = true;
    frame(performance.now());
    running = was;
  };
  faceImg.src = '/face7.jpeg';

  // ---- the low-res target the water renders into --------------------------
  const sceneTex = gl.createTexture();
  gl.bindTexture(gl.TEXTURE_2D, sceneTex);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.NEAREST);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.NEAREST);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);

  const fbo = gl.createFramebuffer();

  let cols = 0, rows = 0, cellW = 0, cellH = 0, aspect = 1;
  const hole = new Float32Array(4);   // text gap bounds, in cell coords

  // ---- colours -------------------------------------------------------------
  const hexToRgb = (hex) => {
    const n = parseInt(hex.slice(1), 16);
    return [(n >> 16 & 255) / 255, (n >> 8 & 255) / 255, (n & 255) / 255];
  };

  let SUN_TINT, WATER_COL;
  function refreshColours() {
    SUN_TINT  = hexToRgb(CONFIG.sunCol);
    WATER_COL = hexToRgb(CONFIG.waterCol).map((v) => Math.pow(v, 2.2));  // sRGB -> linear
  }
  refreshColours();

  // ---- ripple pool --------------------------------------------------------
  const rip = new Float32Array(MAX * 4);
  let ripSlot = 0;
  let clock = 0;

  function addRipple(x, z, strength) {
    const i = ripSlot * 4;
    rip[i]     = x;
    rip[i + 1] = z;
    rip[i + 2] = clock;
    rip[i + 3] = strength;
    ripSlot = (ripSlot + 1) % MAX;
  }

  // Mirror of the shader's camera, so a ripple lands under the cursor at any
  // elevation, including looking straight down.
  function screenToWater(px, py) {
    const w = canvas.clientWidth, h = canvas.clientHeight;
    const x = (0.5 * w - px) / h;   // mirrored to match the flipped scene
    const y = (0.5 * h - py) / h;

    const a = Math.min(Math.max(CONFIG.angle, 5), 89) * Math.PI / 180;
    const ro = [0, ORBIT * Math.sin(a), ORBIT * Math.cos(a)];

    const ww = [0, -Math.sin(a), -Math.cos(a)];
    const cx = [-ww[2], 0, ww[0]];
    const cl = Math.hypot(cx[0], cx[1], cx[2]);
    const uu = [cx[0] / cl, cx[1] / cl, cx[2] / cl];
    const vv = [
      uu[1] * ww[2] - uu[2] * ww[1],
      uu[2] * ww[0] - uu[0] * ww[2],
      uu[0] * ww[1] - uu[1] * ww[0],
    ];

    let rd = [
      x * uu[0] + y * vv[0] + 1.6 * ww[0],
      x * uu[1] + y * vv[1] + 1.6 * ww[1],
      x * uu[2] + y * vv[2] + 1.6 * ww[2],
    ];
    const n = Math.hypot(rd[0], rd[1], rd[2]);
    rd = [rd[0] / n, rd[1] / n, rd[2] / n];

    if (rd[1] > -0.01) return null;
    const t = -ro[1] / rd[1];
    if (t > 60) return null;
    return [ro[0] + rd[0] * t, ro[2] + rd[2] * t];
  }

  // ---- cursor trail -------------------------------------------------------
  // Gated on time *and* distance from the last emitted point: a still cursor
  // leaves nothing, a slow drag leaves a continuous wake, a fast flick drops
  // fewer but stronger ripples instead of a solid smear.
  let lastT = 0, lastX = null, lastY = null;

  canvas.addEventListener('pointermove', (e) => {
    const r = canvas.getBoundingClientRect();
    const x = e.clientX - r.left;
    const y = e.clientY - r.top;
    const now = performance.now();

    if (lastX === null) { lastX = x; lastY = y; lastT = now; return; }

    const dt = now - lastT;
    const d  = Math.hypot(x - lastX, y - lastY);
    if (dt < CONFIG.trailMs || d < CONFIG.trailPx) return;

    const hit = screenToWater(x, y);
    if (hit) {
      const v = d / dt;                                     // px per ms
      addRipple(hit[0], hit[1], 0.007 + Math.min(v * 0.010, 0.013));
    }
    lastX = x; lastY = y; lastT = now;
  });

  canvas.addEventListener('pointerleave', () => { lastX = null; });

  // a deliberate click still drops one proper stone
  canvas.addEventListener('pointerdown', (e) => {
    const r = canvas.getBoundingClientRect();
    const hit = screenToWater(e.clientX - r.left, e.clientY - r.top);
    if (hit) addRipple(hit[0], hit[1], 0.030);
  });

  // ---- sizing -------------------------------------------------------------
  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const w = Math.round(canvas.clientWidth * dpr);
    const h = Math.round(canvas.clientHeight * dpr);
    if (w === 0 || h === 0) return;

    if (canvas.width !== w || canvas.height !== h) {
      canvas.width = w;
      canvas.height = h;
    }
    aspect = w / h;

    cellW = Math.max(2, CONFIG.cellW * dpr);
    cellH = Math.max(2, CONFIG.cellH * dpr);

    // face overlay: full hero height, flush right; hidden when the
    // remaining space can't fit the text gap (e.g. phones)
    const fw = h * faceAspect;
    faceOn = faceReady && w - fw >= 360 * dpr;
    if (faceOn) {
      faceRect[0] = w - fw;
      faceRect[1] = 0;
      faceRect[2] = w;
      faceRect[3] = h;
    }

    // rectangular gap for the hero text, snapped to whole cells —
    // centered in the space left of the face (screen-centered without it)
    const availLeft = faceOn ? w - fw : w;
    const gw = Math.min(680 * dpr, availLeft * 0.9);
    const gh = Math.min(240 * dpr, h * 0.32);
    // biased right of centre, toward the face
    const cx = faceOn ? availLeft * 0.7 : w / 2;
    hole[0] = Math.round((cx - gw / 2) / cellW);
    hole[1] = Math.round((h - gh) / 2 / cellH);
    hole[2] = Math.round((cx + gw / 2) / cellW) - 1;
    hole[3] = Math.round((h + gh) / 2 / cellH) - 1;
    hero.style.setProperty('--hole-x', cx / dpr + 'px');

    const nc = Math.max(1, Math.ceil(w / cellW));
    const nr = Math.max(1, Math.ceil(h / cellH));
    if (nc !== cols || nr !== rows) {
      cols = nc;
      rows = nr;
      gl.bindTexture(gl.TEXTURE_2D, sceneTex);
      gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, cols, rows, 0, gl.RGBA, gl.UNSIGNED_BYTE, null);
      gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
      gl.framebufferTexture2D(gl.FRAMEBUFFER, gl.COLOR_ATTACHMENT0, gl.TEXTURE_2D, sceneTex, 0);
      gl.bindFramebuffer(gl.FRAMEBUFFER, null);
    }
  }
  window.addEventListener('resize', resize);

  // ---- loop ---------------------------------------------------------------
  const calm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const rate = calm ? 0.25 : 1.0;

  let last = performance.now();
  let running = true;

  document.addEventListener('visibilitychange', () => {
    running = !document.hidden;
    if (running) { last = performance.now(); requestAnimationFrame(frame); }
  });

  function bindQuad(loc) {
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.enableVertexAttribArray(loc);
    gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
  }

  function frame(now) {
    if (!running) return;
    const dt = Math.min((now - last) / 1000, 0.05);
    last = now;
    clock += dt * rate;

    resize();

    // pass 1 — water into the cell grid
    gl.bindFramebuffer(gl.FRAMEBUFFER, fbo);
    gl.viewport(0, 0, cols, rows);
    gl.useProgram(scenePM);
    bindQuad(S.aPos);
    gl.uniform2f(S.res, cols, rows);
    gl.uniform1f(S.aspect, aspect);
    gl.uniform1f(S.time, clock);
    gl.uniform1f(S.wind, CONFIG.wind);
    gl.uniform1f(S.sun, CONFIG.sun);
    gl.uniform1f(S.angle, CONFIG.angle);
    gl.uniform1f(S.ripSpeed, CONFIG.speed);
    gl.uniform3fv(S.sunTint, SUN_TINT);
    gl.uniform3fv(S.waterCol, WATER_COL);
    gl.uniform4fv(S.rip, rip);
    gl.drawArrays(gl.TRIANGLES, 0, 3);

    // pass 2 — wave glyphs
    gl.bindFramebuffer(gl.FRAMEBUFFER, null);
    gl.viewport(0, 0, canvas.width, canvas.height);
    gl.useProgram(asciiPM);
    bindQuad(A.aPos);
    gl.activeTexture(gl.TEXTURE0);
    gl.bindTexture(gl.TEXTURE_2D, sceneTex);
    gl.uniform1i(A.scene, 0);
    gl.activeTexture(gl.TEXTURE1);
    gl.bindTexture(gl.TEXTURE_2D, atlas.tex);
    gl.uniform1i(A.glyphs, 1);
    gl.uniform2f(A.cell, cellW, cellH);
    gl.uniform2f(A.grid, cols, rows);
    gl.uniform2f(A.res, canvas.width, canvas.height);
    gl.uniform1f(A.count, atlas.count);
    gl.uniform1f(A.levels, CONFIG.levels);
    gl.uniform1f(A.bg, CONFIG.glowBg);
    gl.uniform1f(A.contrast, CONFIG.contrast);
    gl.uniform1f(A.lift, CONFIG.lift);
    gl.uniform4fv(A.hole, hole);
    gl.activeTexture(gl.TEXTURE2);
    gl.bindTexture(gl.TEXTURE_2D, faceTex);
    gl.uniform1i(A.face, 2);
    gl.uniform4fv(A.faceRect, faceRect);
    gl.uniform1f(A.faceOn, faceOn ? 1 : 0);
    gl.drawArrays(gl.TRIANGLES, 0, 3);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
