---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<header class="water-hero">
  <canvas id="gl"></canvas>
  <pre id="err"></pre>
  <div class="hero-text">
    <h1>{title}</h1>
    {subtitle && <p>{subtitle}</p>}
  </div>
</header>

<style>
  .water-hero {
    position: relative;
    height: 100vh;
    height: 100svh;
    background: #06131c;
    overflow: hidden;
  }
  #gl {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    touch-action: none;
    cursor: crosshair;
  }
  #err {
    position: absolute;
    inset: 0;
    display: none;
    place-items: center;
    padding: 32px;
    background: #06131c;
    color: #ff9d8a;
    font-family: ui-monospace, 'SFMono-Regular', 'Menlo', 'Consolas', monospace;
    font-size: 12px;
    line-height: 1.6;
    white-space: pre-wrap;
    overflow: auto;
    z-index: 5;
  }
  .hero-text {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    place-items: center;
    text-align: center;
    pointer-events: none;
    color: #fff;
    padding: 0 24px;
  }
  .hero-text h1 {
    margin: 0 0 0.35em;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    text-shadow: 0 2px 28px rgba(6, 19, 28, 0.5);
  }
  .hero-text p {
    margin: 0;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    font-weight: 300;
    opacity: 0.92;
    text-shadow: 0 1px 18px rgba(6, 19, 28, 0.5);
  }
</style>

<script is:inline>
(() => {
  // ---- settings -----------------------------------------------------------
  // Everything tunable lives here. No panel, no URL state, no storage.
  const CONFIG = {
    wind:     0.29,      // 0..1   wave height + choppiness
    angle:    20,        // 20..89 camera elevation above the water, degrees
    sun:      0.37,      // 0..1   sun height in the sky
    speed:    0.75,      // 0.25..2.6  ripple wavefront speed
    sunCol:   '#ff4000',
    waterCol: '#007bff',
    ripples:  true,      // click to drop a ripple
  };

  const canvas = document.getElementById('gl');
  const errBox = document.getElementById('err');

  function fail(msg) {
    errBox.textContent = msg;
    errBox.style.display = 'grid';
  }

  const gl = canvas.getContext('webgl', { antialias: false, alpha: false, powerPreference: 'high-performance' })
          || canvas.getContext('experimental-webgl');

  if (!gl) {
    fail('This browser has no WebGL context available.\nTry another browser, or enable hardware acceleration.');
    return;
  }

  const VERT = `
    attribute vec2 aPos;
    void main() { gl_Position = vec4(aPos, 0.0, 1.0); }
  `;

  const FRAG = `
    precision highp float;

    uniform vec2  uRes;
    uniform float uTime;
    uniform float uWind;
    uniform float uSun;
    uniform vec3  uSunTint;
    uniform vec3  uWaterCol;  // linear-light colour; drives body + absorption
    uniform float uAngle;     // camera elevation, degrees above the water
    uniform float uRipSpeed;
    uniform vec4  uRip[8];    // xy = world xz, z = birth time, w = strength

    const float ORBIT = 6.39;   // camera distance from the origin, held constant

    // ---- value noise ------------------------------------------------------
    float hash(vec2 p) {
      p = fract(p * vec2(443.897, 441.423));
      p += dot(p, p.yx + 19.19);
      return fract((p.x + p.y) * p.x);
    }

    float noise(vec2 p) {
      vec2 i = floor(p);
      vec2 f = fract(p);
      vec2 u = f * f * (3.0 - 2.0 * f);
      float a = hash(i);
      float b = hash(i + vec2(1.0, 0.0));
      float c = hash(i + vec2(0.0, 1.0));
      float d = hash(i + vec2(1.0, 1.0));
      return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
    }

    float fbm(vec2 p) {
      float v = 0.0;
      float a = 0.5;
      mat2 r = mat2(0.86, -0.51, 0.51, 0.86);
      for (int i = 0; i < 4; i++) {
        v += a * noise(p);
        p = r * p * 2.03;
        a *= 0.5;
      }
      return v;
    }

    // ---- surface height ---------------------------------------------------
    // detail fades with distance so far-off waves don't alias into noise.
    float swell(vec2 p, float detail) {
      float h = 0.0;
      float amp = 0.5;
      float freq = 0.85;
      vec2 q = p;
      mat2 rot = mat2(0.86, -0.51, 0.51, 0.86);

      for (int i = 0; i < 6; i++) {
        float lod = (i < 2) ? 1.0 : detail;
        vec2 drift = vec2(0.85, 0.32) * uTime * (0.22 + 0.10 * float(i));
        float n = noise(q * freq + drift) * 2.0 - 1.0;
        h += n * amp * lod;
        q = rot * q;
        amp *= 0.54;
        freq *= 2.06;
      }

      // sharpen crests, round out troughs -- the shape wind actually makes
      float chop = 0.30 + 0.45 * uWind;
      h = sign(h) * pow(abs(h), 1.0 - 0.55 * chop);
      return h * (0.10 + 0.30 * uWind);
    }

    // Capillary chop: tiny fast wavelets that only really touch the normal.
    // Without these the surface reads as a stretched rubber sheet.
    float capillary(vec2 p, float detail) {
      float a = noise(p *  9.0 + vec2(-uTime * 0.55, uTime * 0.40)) - 0.5;
      float b = noise(p * 19.0 + vec2( uTime * 0.80, uTime * 0.25)) - 0.5;
      return (a * 0.0090 + b * 0.0040) * (0.35 + uWind) * detail;
    }

    float ripples(vec2 p) {
      float h = 0.0;
      for (int i = 0; i < 8; i++) {
        vec4 r = uRip[i];
        if (r.w <= 0.0) continue;
        float age = uTime - r.z;
        if (age < 0.0 || age > 7.0) continue;
        float d = length(p - r.xy);
        float front = d - age * uRipSpeed;                  // expanding wavefront
        float env = exp(-age * 1.15) * exp(-front * front * 30.0) * exp(-d * 0.22);
        float s = sin(front * 26.0);
        s = sign(s) * pow(abs(s), 1.45);                    // peaked crest, flat trough
        h += (s + 0.30 * sin(front * 52.0 + 1.0)) * env * r.w;
      }
      return h;
    }

    float height(vec2 p, float detail) {
      return swell(p, detail) + ripples(p) + capillary(p, detail);
    }

    vec3 normalAt(vec2 p, float eps, float detail) {
      float h  = height(p, detail);
      float hx = height(p + vec2(eps, 0.0), detail);
      float hz = height(p + vec2(0.0, eps), detail);
      return normalize(vec3(h - hx, eps, h - hz));
    }

    // ---- sky --------------------------------------------------------------
    vec3 sky(vec3 rd, vec3 sunDir) {
      float y = max(rd.y, 0.0);
      vec3 zenith  = vec3(0.05, 0.26, 0.62);
      vec3 horizon = vec3(0.68, 0.80, 0.88);
      horizon = mix(horizon, uSunTint, 0.28);   // sun colour bleeds into the haze
      vec3 col = mix(horizon, zenith, pow(y, 0.45));

      // thin cloud band near the horizon
      float band = exp(-abs(rd.y - 0.16) * 14.0);
      float c = fbm(rd.xz / max(rd.y + 0.10, 0.10) * 0.9 + uTime * 0.012);
      col = mix(col, mix(vec3(0.93, 0.94, 0.95), uSunTint, 0.35), smoothstep(0.45, 0.85, c) * band * 0.55);

      float sd = max(dot(rd, sunDir), 0.0);
      col += uSunTint * pow(sd, 900.0) * 14.0;   // disc
      col += uSunTint * pow(sd, 7.0) * 0.30;     // glow
      return col;
    }

    // ---- sea floor --------------------------------------------------------
    float caustic(vec2 p) {
      float a = noise(p * 2.6 + vec2( uTime * 0.11, -uTime * 0.08));
      float b = noise(p * 4.3 - vec2( uTime * 0.09,  uTime * 0.12));
      float v = abs(a - b);
      return pow(1.0 - clamp(v * 3.2, 0.0, 1.0), 7.0);
    }

    vec3 floorColor(vec2 p) {
      float grain = fbm(p * 1.4);
      vec3 sand = mix(vec3(0.42, 0.40, 0.31), vec3(0.60, 0.57, 0.44), grain);
      sand += vec3(1.00, 0.92, 0.70) * caustic(p) * 0.55;
      return sand;
    }

    void main() {
      vec2 uv = (gl_FragCoord.xy - 0.5 * uRes) / uRes.y;

      // camera: swings up an arc of fixed radius. 20 deg is the grazing view,
      // 89 deg is effectively straight down.
      float ang = radians(clamp(uAngle, 5.0, 89.0));
      vec3 ro = vec3(0.0, ORBIT * sin(ang), ORBIT * cos(ang));
      vec3 ww = normalize(-ro);
      vec3 uu = normalize(cross(ww, vec3(0.0, 1.0, 0.0)));
      vec3 vv = cross(uu, ww);
      vec3 rd = normalize(uv.x * uu + uv.y * vv + 1.60 * ww);

      float el = mix(0.05, 0.72, uSun);
      vec3 sunDir = normalize(vec3(0.30, el, -1.0));

      vec3 col;

      if (rd.y > -0.0025) {
        col = sky(rd, sunDir);
      } else {
        float t = -ro.y / rd.y;
        vec3 pos = ro + rd * t;
        vec2 p = pos.xz;

        float detail = 1.0 / (1.0 + t * t * 0.0055);
        float eps = max(0.0045, t * 0.0022);
        vec3 N = normalAt(p, eps, detail);
        vec3 V = -rd;

        // what shows through the surface
        vec3 refr = refract(rd, N, 1.0 / 1.333);
        float depth = 1.35;
        vec2 fp = p + refr.xz * (depth / max(-refr.y, 0.25));
        vec3 below = floorColor(fp);

        // Absorption is derived from the water colour: whatever channels are
        // darkened get absorbed fastest, so the depths converge on that hue.
        vec3 tint = max(uWaterCol, vec3(0.015));
        vec3 absorbK = -log(tint) * 0.42;
        below *= exp(-absorbK * depth * 1.9);
        below = mix(below, tint * 0.70, 0.48);

        // reflection
        vec3 R = reflect(rd, N);
        R.y = abs(R.y);
        vec3 above = sky(R, sunDir);

        float fres = 0.02 + 0.98 * pow(1.0 - max(dot(N, V), 0.0), 5.0);
        col = mix(below, above, fres);

        // sun glitter
        vec3 H = normalize(sunDir + V);
        float spec = pow(max(dot(N, H), 0.0), 600.0);
        col += uSunTint * spec * 4.0;

        // foam where crests are steep
        float h = height(p, detail);
        float steep = 1.0 - N.y;
        float foam = smoothstep(0.35, 0.85, h * 6.0 * (0.4 + uWind)) * smoothstep(0.02, 0.12, steep);
        foam *= smoothstep(0.35, 0.75, fbm(p * 7.0 + uTime * 0.25));
        col = mix(col, vec3(0.92, 0.95, 0.96), clamp(foam, 0.0, 0.75) * detail);

        // haze into the horizon
        float haze = 1.0 - exp(-t * 0.055);
        col = mix(col, sky(vec3(rd.x, 0.008, rd.z), sunDir), haze * 0.92);
      }

      // tonemap + a touch of contrast
      col = col / (1.0 + col);
      col = pow(col, vec3(0.4545));
      col = mix(vec3(dot(col, vec3(0.299, 0.587, 0.114))), col, 1.32);

      // vignette
      vec2 q = gl_FragCoord.xy / uRes;
      col *= 0.80 + 0.20 * pow(16.0 * q.x * q.y * (1.0 - q.x) * (1.0 - q.y), 0.18);

      gl_FragColor = vec4(clamp(col, 0.0, 1.0), 1.0);
    }
  `;

  function compile(type, src) {
    const s = gl.createShader(type);
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      throw new Error(gl.getShaderInfoLog(s) || 'shader compile failed');
    }
    return s;
  }

  let prog;
  try {
    prog = gl.createProgram();
    gl.attachShader(prog, compile(gl.VERTEX_SHADER, VERT));
    gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, FRAG));
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      throw new Error(gl.getProgramInfoLog(prog) || 'program link failed');
    }
  } catch (e) {
    fail('Shader problem:\n\n' + e.message);
    return;
  }

  gl.useProgram(prog);

  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
  const aPos = gl.getAttribLocation(prog, 'aPos');
  gl.enableVertexAttribArray(aPos);
  gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

  const uRes      = gl.getUniformLocation(prog, 'uRes');
  const uTime     = gl.getUniformLocation(prog, 'uTime');
  const uWind     = gl.getUniformLocation(prog, 'uWind');
  const uSun      = gl.getUniformLocation(prog, 'uSun');
  const uSunTint  = gl.getUniformLocation(prog, 'uSunTint');
  const uWaterCol = gl.getUniformLocation(prog, 'uWaterCol');
  const uAngle    = gl.getUniformLocation(prog, 'uAngle');
  const uRipSpeed = gl.getUniformLocation(prog, 'uRipSpeed');
  const uRip      = gl.getUniformLocation(prog, 'uRip[0]');

  const ORBIT = 6.39;   // must match the shader

  // ---- colours, resolved once ---------------------------------------------
  const hexToRgb = (hex) => {
    const n = parseInt(hex.slice(1), 16);
    return [(n >> 16 & 255) / 255, (n >> 8 & 255) / 255, (n & 255) / 255];
  };
  const SUN_TINT  = hexToRgb(CONFIG.sunCol);
  const WATER_COL = hexToRgb(CONFIG.waterCol).map((v) => Math.pow(v, 2.2));  // sRGB -> linear

  // ---- ripple pool --------------------------------------------------------
  const MAX = 8;
  const rip = new Float32Array(MAX * 4);
  let ripSlot = 0;
  let clock = 0;

  function addRipple(x, z, strength) {
    const i = ripSlot * 4;
    rip[i]     = x;
    rip[i + 1] = z;
    rip[i + 2] = clock;
    rip[i + 3] = strength;
    ripSlot = (ripSlot + 1) % MAX;
  }

  // Mirror of the shader's camera, so a click lands where you clicked.
  function screenToWater(px, py) {
    const w = canvas.clientWidth, h = canvas.clientHeight;
    const x = (px - 0.5 * w) / h;
    const y = (0.5 * h - py) / h;

    const a = Math.min(Math.max(CONFIG.angle, 5), 89) * Math.PI / 180;
    const ro = [0, ORBIT * Math.sin(a), ORBIT * Math.cos(a)];

    const ww = [0, -Math.sin(a), -Math.cos(a)];
    // cross(ww, up) with up = (0,1,0) reduces to (-ww.z, 0, ww.x)
    const cx = [-ww[2], 0, ww[0]];
    const cl = Math.hypot(cx[0], cx[1], cx[2]);
    const uu = [cx[0] / cl, cx[1] / cl, cx[2] / cl];
    const vv = [
      uu[1] * ww[2] - uu[2] * ww[1],
      uu[2] * ww[0] - uu[0] * ww[2],
      uu[0] * ww[1] - uu[1] * ww[0],
    ];

    let rd = [
      x * uu[0] + y * vv[0] + 1.6 * ww[0],
      x * uu[1] + y * vv[1] + 1.6 * ww[1],
      x * uu[2] + y * vv[2] + 1.6 * ww[2],
    ];
    const n = Math.hypot(rd[0], rd[1], rd[2]);
    rd = [rd[0] / n, rd[1] / n, rd[2] / n];

    if (rd[1] > -0.01) return null;          // aimed at the sky
    const t = -ro[1] / rd[1];
    if (t > 60) return null;                 // too far out to matter
    return [ro[0] + rd[0] * t, ro[2] + rd[2] * t];
  }

  if (CONFIG.ripples) {
    canvas.addEventListener('pointerdown', (e) => {
      const r = canvas.getBoundingClientRect();
      const hit = screenToWater(e.clientX - r.left, e.clientY - r.top);
      if (hit) addRipple(hit[0], hit[1], 0.030);
    });
  }

  // ---- sizing -------------------------------------------------------------
  // Render at up to 1.5x; the shader is per-pixel and heavy.
  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
    const w = Math.round(canvas.clientWidth * dpr);
    const h = Math.round(canvas.clientHeight * dpr);
    if (canvas.width !== w || canvas.height !== h) {
      canvas.width = w;
      canvas.height = h;
      gl.viewport(0, 0, w, h);
    }
  }
  window.addEventListener('resize', resize);

  // ---- loop ---------------------------------------------------------------
  const calm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const rate = calm ? 0.25 : 1.0;

  let last = performance.now();
  let running = true;

  document.addEventListener('visibilitychange', () => {
    running = !document.hidden;
    if (running) { last = performance.now(); requestAnimationFrame(frame); }
  });

  function frame(now) {
    if (!running) return;
    const dt = Math.min((now - last) / 1000, 0.05);
    last = now;
    clock += dt * rate;

    resize();
    gl.uniform2f(uRes, canvas.width, canvas.height);
    gl.uniform1f(uTime, clock);
    gl.uniform1f(uWind, CONFIG.wind);
    gl.uniform1f(uSun, CONFIG.sun);
    gl.uniform1f(uAngle, CONFIG.angle);
    gl.uniform1f(uRipSpeed, CONFIG.speed);
    gl.uniform3fv(uSunTint, SUN_TINT);
    gl.uniform3fv(uWaterCol, WATER_COL);
    gl.uniform4fv(uRip, rip);
    gl.drawArrays(gl.TRIANGLES, 0, 3);

    requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
